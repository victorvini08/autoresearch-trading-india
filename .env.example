# ─────────────────────────────────────────────────────────────────────
# Dhan HQ Trading API (free)
# Generate at: https://web.dhan.co  →  DhanHQ Trading APIs
# Access token is valid ~1 year; rotate annually.
# ─────────────────────────────────────────────────────────────────────
DHAN_ACCESS_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.example.replace_me
DHAN_CLIENT_ID=1000001234

# Set DHAN_MOCK=1 to bypass real Dhan calls and use the in-memory mock
# broker (brokers/dhan_mock.py). Required for v1 paper-only operation
# before you obtain a real Dhan access token.
DHAN_MOCK=1

# ─────────────────────────────────────────────────────────────────────
# SEBI retail algo framework compliance (mandatory from 2026-04-01)
# Register the algo with Dhan to obtain a unique algo ID. Stamped on
# every order placed by the executor.
# ─────────────────────────────────────────────────────────────────────
SEBI_ALGO_ID=PERSONAL_ALGO_REPLACE_ME

# ─────────────────────────────────────────────────────────────────────
# FRED API (free; for India macro indicators: CPI, repo proxy, USD/INR)
# Sign up at: https://fred.stlouisfed.org/docs/api/api_key.html
# ─────────────────────────────────────────────────────────────────────
FRED_API_KEY=replace_me

# ─────────────────────────────────────────────────────────────────────
# Optional: override default storage / state directories (relative to repo root)
# ─────────────────────────────────────────────────────────────────────
# STORAGE_DIR=storage
# STATE_DIR=state

# ─────────────────────────────────────────────────────────────────────
# Optional: LLM provider override (default: claude-code-sdk via local CLI auth)
# ─────────────────────────────────────────────────────────────────────
# LLM_PROVIDER=claude   # or 'codex', 'qwen'
# LLM_MODEL_AUTORESEARCH=claude-opus-4-7
# LLM_MODEL_CLASSIFIER=claude-sonnet-4-6
