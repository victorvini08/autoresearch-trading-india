<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Pre-market scan — 10:00 IST (45 min after NSE open at 09:15).

  Uses yfinance to pull today's NSE open + India VIX (Yahoo's data for
  Indian markets is ~15-min delayed; running at 10:00 gives a clean
  margin over the 09:15 official open). Detects gaps vs prior bhav
  close and flags names for run_live to skip. Read-only; never places
  orders.

  Install:
    1. Confirm WorkingDirectory + the uv path below match this machine.
    2. cp this file to ~/Library/LaunchAgents/
    3. launchctl load ~/Library/LaunchAgents/com.autoresearch.premarket_scan.plist
    4. Verify: launchctl list | grep premarket_scan

  Logs to state/logs/premarket_scan.{out,err}.log. Machine clock is IST.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.autoresearch.premarket_scan</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/sh</string>
    <string>-c</string>
    <string>cd "/Users/aryanmehta/Desktop/My Work/autoresearch-trading-india" &amp;&amp; /opt/homebrew/bin/uv run python -m scripts.premarket_scan</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>10</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/aryanmehta/Desktop/My Work/autoresearch-trading-india/state/logs/premarket_scan.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/aryanmehta/Desktop/My Work/autoresearch-trading-india/state/logs/premarket_scan.err.log</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
